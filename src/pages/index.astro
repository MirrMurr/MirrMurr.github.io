---
import Box from "@components/Box.astro";
import Hero from "@components/Hero.astro";
import Grid from "@components/layout/Grid.astro";
import Overlay from "@components/Overlay.astro";
import Layout from "@layouts/Layout.astro";
import { pages } from "@utils/pageData";

/**
 * TODOs:
 * - [ ] add View Transition animation when navigating to project pages from the index page
 * - [ ] add Timeline(Entry) components to experience and education pages
 *
 */
---

<Layout title="Welcome! 🍻">
  <Hero />
  <br />
  <Grid>
   {pages.filter((page) => page.label !== 'Home').map(({ href, label, color = '', bannerImage = '', bannerImagePosition = '' }) => (
      <a href={href}>
        <Overlay title={label} dimmed dimAmount={0.5}>
          <Box image={bannerImage} color={color} width="100%" aspectRatio={1} backgroundPosition={bannerImagePosition} />
        </Overlay>
      </a>
    ))}
  </Grid>
</Layout>

<style>
  .grid-item {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 100%;
    aspect-ratio: 1;
    padding: 1rem;
    text-align: center;
    background-color: #eee;
  }

  a::after {
    display: none;
  }

</style>