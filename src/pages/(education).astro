---
import SubPageHero from "@components/SubPageHero.astro";
import Layout from "@layouts/Layout.astro";
import { pages } from "@data/pageData";

const page = pages.find((page) => page.key === "education");
---

<Layout title={page?.title || ''}>
  <SubPageHero {...page} />
  <br />
  <p>This is the education page.</p>
</Layout>
