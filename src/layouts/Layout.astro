---
import Footer from "@components/Footer.astro";
import Nav from "@components/Nav.astro";
import ScrollToTop from "@components/ScrollToTop.astro";
import ProgressBar from "@components/ProgressBar.astro";

import "@styles/index.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Portfolio website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bitcount+Prop+Double+Ink:wght@100..900&family=Press+Start+2P&family=Roboto+Condensed:ital,wght@0,100..900;1,100..900&family=Rubik+80s+Fade&family=Zen+Dots&display=swap" rel="stylesheet">

    <title>{title}</title>
  </head>
  <body>
    <div id="page" class="with-transition">
    <Nav />
    <div class="content-container">
      <main>
        <slot />
      </main>
      <ScrollToTop />
      <Footer />
        <ProgressBar variant="scroll" position="bottom" />
      </div>
    </div>
  </body>
</html>

<style is:global>
  :root {
    --primary-color: rgb(190, 56, 56);
    --secondary-color: #1c1c1c;
    --off-white: rgb(246, 246, 246);

    --header-color: white;
    --background-color: var(--off-white);

    --text-color: #222222;
    --text-color-secondary: #888888;

    --shadow-color: 0deg 0% 50%;
    --shadow-elevation-low: 0px 0.5px 0.6px hsl(var(--shadow-color) / 0.31),
      0px 1px 1.3px -0.8px hsl(var(--shadow-color) / 0.41),
      0px 2.3px 2.9px -1.6px hsl(var(--shadow-color) / 0.52);
    --shadow-elevation-medium: 0px 0.5px 0.6px hsl(var(--shadow-color) / 0.32),
      0px 2.2px 2.8px -0.5px hsl(var(--shadow-color) / 0.41),
      0px 5.1px 6.4px -1.1px hsl(var(--shadow-color) / 0.49),
      0px 11.7px 14.7px -1.6px hsl(var(--shadow-color) / 0.57);
    --shadow-elevation-high: 0px 0.5px 0.6px hsl(var(--shadow-color) / 0.3),
      0px 4.8px 6px -0.2px hsl(var(--shadow-color) / 0.34),
      0px 8.9px 11.1px -0.5px hsl(var(--shadow-color) / 0.38),
      0px 14px 17.5px -0.7px hsl(var(--shadow-color) / 0.42),
      0px 21.2px 26.6px -0.9px hsl(var(--shadow-color) / 0.46),
      0.1px 31.7px 39.7px -1.2px hsl(var(--shadow-color) / 0.49),
      0.1px 46.6px 58.4px -1.4px hsl(var(--shadow-color) / 0.53),
      0.1px 67.3px 84.3px -1.6px hsl(var(--shadow-color) / 0.57);
  }

  *,
  *::before,
  *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  *::selection {
    background-color: var(--primary-color);
    color: white;
  }

  html,
  body {
    font-family:  "Roboto Condensed", "Bitcount Prop Double Ink", systems-ui, sans-serif;
    background-color: var(--background-color);
    color: var(--text-color);
    font-style: normal;
    text-align: justify;
    /* font-optical-sizing: auto; */
    line-height: 1.5;
  }

  main {
    padding: 2rem 0;
    flex: 1;
  }

  #page {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  .content-container {
    width: 90vw;
    display: flex;
    flex-direction: column;
    align-self: center;
    background-color: var(--background-color);
    flex: 1;
  }

  @media only screen and (min-width: 568px) {
    .content-container {
      width: 80vw;
    }
  }

  @media only screen and (min-width: 1024px) {
    .content-container {
      width: 70vw;
    }
  }

  @media only screen and (min-width: 1440px) {
    .content-container {
      width: 60vw;
    }
  }

  @media only screen and (min-width: 1920px) {
    .content-container {
      width: 50vw;
    }
  }
</style>
