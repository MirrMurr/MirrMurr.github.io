---
import { type PageInfo } from "@data/pageData";
import Overlay from "./Overlay.astro";
import Box from "./Box.astro";
import Tile from "./Tile.astro";

interface Props extends Partial<PageInfo> {}

const { key = "", title = "", bannerImage = "", bannerImagePosition = "" } = Astro.props;
---

<Tile key={key}>
  <Overlay title={title} dimmed dimAmount={0.01} titleBackdrop>
    <Box
      image={bannerImage}
      height="200px"
      width="100%"
      backgroundPosition={bannerImagePosition}
      loading="eager"
    />
  </Overlay>
</Tile>