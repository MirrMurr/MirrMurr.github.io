---
import GitHub from "@assets/icons/github.svg";
import WhatsApp from "@assets/icons/whatsapp.svg";
import EmailLetter from "@assets/icons/email-letter.svg";
import LinkedIn from "@assets/icons/linkedin-outline.svg";
import clsx from "clsx";
import { Image } from "astro:assets";

interface Props {
  layout?: "row" | "grid";
  emailHref?: string;
  whatsappHref?: string;
  githubHref?: string;
  linkedinHref?: string;
}

const {
  layout = "row",
  emailHref = "mailto:punches_quarts_8p@icloud.com",
  whatsappHref = "https://wa.me/0798105453",
  githubHref = "https://github.com/MirrMurr",
  linkedinHref = "https://www.linkedin.com/in/adam-kara-2502301a5/",
} = Astro.props;
---

<div class={clsx("contact-icons", `contact-icons--${layout}`)}>
  <a href={emailHref} target="_blank" rel="noopener noreferrer" class="contact-link">
    <Image src={EmailLetter} alt="Email" class="contact-icon" loading="lazy" />
  </a>
  <a href={whatsappHref} target="_blank" rel="noopener noreferrer" class="contact-link">
    <Image src={WhatsApp} alt="WhatsApp" class="contact-icon" loading="lazy" />
  </a>
  <a href={githubHref} target="_blank" rel="noopener noreferrer" class="contact-link">
    <Image src={GitHub} alt="GitHub" class="contact-icon" loading="lazy" />
  </a>
  <a href={linkedinHref} target="_blank" rel="noopener noreferrer" class="contact-link">
    <Image src={LinkedIn} alt="LinkedIn" class="contact-icon" loading="lazy" />
  </a>
</div>

<style>
  .contact-icons {
    width: fit-content;
    display: flex;
    gap: 1rem;
    color: var(--primary-color);
  }

  .contact-icon {
    width: 2rem;
    height: 2rem;
    background-color: transparent;
    filter: brightness(0);
  }

  :global(html[data-theme='dark']) .contact-icon {
    filter: brightness(1) invert(1);
  }

  .contact-icons--grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .contact-icons--row {
    justify-content: center;
  }

  .contact-link {
    display: flex;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .contact-link:hover {
    transform: scale(1.1);
    opacity: 0.8;
  }
</style>